#!/bin/sh

# プッシュされるコミットに含まれるファイルのみチェック
UPSTREAM=$(git rev-parse --abbrev-ref --symbolic-full-name @{upstream} 2>/dev/null | sed 's|refs/remotes/||')
if [ -n "$UPSTREAM" ] && git diff --name-only "$UPSTREAM"...HEAD | grep -qE "src/components|src/hooks|tests/"; then
  echo "Running pre-push UI tests for relevant changes..."
  pnpm vitest run -c tests/vitest.ui.config.ts
  TEST_EXIT_CODE=$?
  if [ $TEST_EXIT_CODE -ne 0 ]; then
    echo "UI Tests failed with code $TEST_EXIT_CODE"
    exit $TEST_EXIT_CODE
  fi
  echo "Pre-push UI tests passed!"
else
  echo "No UI-related changes detected in this push. Skipping UI tests."
fi

exit 0
