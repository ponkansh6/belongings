{
  "name": "belongings",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "preinstall": "pnpm dlx only-allow pnpm",
    "tsgo": "tsgo",
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "test": "pnpm dlx bun test",
    "test:watch": "pnpm dlx bun test --watch",
    "test:ui": "vitest run -c tests/vitest.ui.config.ts --reporter=verbose",
    "test:all": "pnpm dlx bun test && vitest run -c tests/vitest.ui.config.ts",
    "test:e2e": "playwright test",
    "lint": "eslint --cache",
    "lint:fast": "oxlint --ignore-pattern 'tests/**' --ignore-pattern 'scripts/ts_converters/**' --nextjs-plugin --react-plugin --react-perf-plugin",
    "check:deps": "depcheck",
    "format:fast": "oxfmt --write .",
    "type-check": "tsc --noEmit",
    "type-check:fast": "tsgo --noEmit",
    "security-check": "pnpm audit --audit-level=high && secretlint \"**/*\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "framer-motion": "^12.40.0",
    "next": "^16.2.7",
    "papaparse": "^5.5.3",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-is": "^19.2.7",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.19.43",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19",
    "@typescript/native-preview": "^7.0.0-dev.20260607.1",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.8",
    "arquero": "^8.0.3",
    "bun-types": "^1.3.14",
    "depcheck": "^1.4.7",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.10.2",
    "husky": "^9.1.7",
    "iconv-lite": "^0.7.2",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.68.0",
    "prettier": "^3.8.1",
    "secretlint": "12.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "xlsx": "^0.18.5"
  }
}
